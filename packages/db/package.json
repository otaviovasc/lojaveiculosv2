{
  "name": "@lojaveiculosv2/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:push": "node ../../tools/db/ensure-local-database-url.mjs DATABASE_URL && drizzle-kit push --config drizzle.config.ts",
    "db:push:force": "node ../../tools/db/ensure-local-database-url.mjs DATABASE_URL && drizzle-kit push --force --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@lojaveiculosv2/shared": "workspace:*",
    "drizzle-orm": "0.45.2"
  },
  "devDependencies": {
    "drizzle-kit": "0.31.10"
  }
}
