{
  "name": "@lojaveiculosv2/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "catalog:normalize-names": "tsx src/jobs/normalizeVehicleCatalogNames.ts",
    "catalog:sync": "tsx src/jobs/syncVehicleCatalog.ts",
    "billing:asaas:sync-smoke": "tsx src/jobs/syncBillingProviderSubscription.ts",
    "crm:whatsapp:schedule:process": "tsx src/jobs/processCrmWhatsappScheduledMessages.ts",
    "build": "tsc -b",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@clerk/backend": "^3.11.4",
    "@hono/node-server": "2.0.8",
    "@hono/zod-openapi": "1.4.0",
    "@lojaveiculosv2/audit": "workspace:*",
    "@lojaveiculosv2/audit-db": "workspace:*",
    "@lojaveiculosv2/config": "workspace:*",
    "@lojaveiculosv2/db": "workspace:*",
    "@lojaveiculosv2/documents": "workspace:*",
    "@lojaveiculosv2/shared": "workspace:*",
    "@react-pdf/renderer": "^4.5.1",
    "@scalar/hono-api-reference": "0.11.9",
    "@sentry/node": "10.65.0",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.29",
    "pdf-lib": "^1.17.1",
    "pino": "10.3.1",
    "postgres": "^3.4.9",
    "react": "19.2.7",
    "redis": "6.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "12.1.0",
    "@types/react": "19.2.17",
    "pino-pretty": "13.1.3",
    "tsx": "4.23.0",
    "vitest": "4.1.10"
  }
}
