{
  "name": "@lojaveiculosv2/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "catalog:normalize-names": "tsx src/jobs/normalizeVehicleCatalogNames.ts",
    "catalog:sync": "tsx src/jobs/syncVehicleCatalog.ts",
    "build": "tsc -b",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@clerk/backend": "^3.8.4",
    "@hono/node-server": "2.0.6",
    "@hono/zod-openapi": "1.4.0",
    "@lojaveiculosv2/audit": "workspace:*",
    "@lojaveiculosv2/audit-db": "workspace:*",
    "@lojaveiculosv2/config": "workspace:*",
    "@lojaveiculosv2/db": "workspace:*",
    "@lojaveiculosv2/shared": "workspace:*",
    "@scalar/hono-api-reference": "0.11.6",
    "@sentry/node": "10.62.0",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.27",
    "pdf-lib": "^1.17.1",
    "pino": "10.3.1",
    "postgres": "^3.4.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "pino-pretty": "13.1.3",
    "tsx": "4.22.4",
    "vitest": "4.1.9"
  }
}
