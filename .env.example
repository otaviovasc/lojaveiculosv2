# Runtime
NODE_ENV=development
APP_ENV=local
PORT=8787
PUBLIC_APP_URL=http://localhost:5173
API_BASE_URL=http://localhost:8787
VITE_API_BASE_URL=/api/v1
VITE_DEV_API_PROXY_TARGET=http://localhost:8787
VITE_DEV_PUBLIC_STORE_HOST=test-store.lojaveiculos.com.br
DB_POOL_MAX=5
DB_CLOSE_TIMEOUT_SECONDS=5
SHUTDOWN_TIMEOUT_MS=10000

# Product databases
# Local Docker defaults. These are development-only credentials from docker-compose.yml.
DATABASE_URL=postgresql://lojaveiculosv2:lojaveiculosv2_dev@localhost:54321/lojaveiculosv2
AUDIT_DATABASE_URL=postgresql://lojaveiculosv2_audit:lojaveiculosv2_audit_dev@localhost:54322/lojaveiculosv2_audit

# Railway production values should be service reference variables, not copied
# local URLs:
# DATABASE_URL=${{lojaveiculosv2-postgres.DATABASE_URL}}
# AUDIT_DATABASE_URL=${{lojaveiculosv2-audit-postgres.DATABASE_URL}}

# Optional infra services
# REDIS_URL=${{redis.REDIS_URL}}
REDIS_URL=redis://localhost:63790

# CRM ZAPI test connection
# Leave secrets empty in committed files. Set RUN_ZAPI_E2E=true only when you
# intentionally want local tests to send/receive real WhatsApp traffic.
CRM_ZAPI_API_BASE_URL=https://api.z-api.io
CRM_ZAPI_TEST_INSTANCE_ID=
CRM_ZAPI_TEST_INSTANCE_TOKEN=
CRM_ZAPI_TEST_CLIENT_TOKEN=
CRM_ZAPI_TEST_PAIR_PHONE=
# Required outside APP_ENV=local; append ?token=... to ZAPI callback URLs
# when custom headers are not available.
CRM_ZAPI_WEBHOOK_TOKEN=
RUN_ZAPI_E2E=false

# Clerk
# Use a dedicated V2 Clerk project; do not reuse V1/Repasses secrets.
CLERK_SECRET_KEY=
# Optional: paste Clerk's JWT public key only if you want networkless
# verification with @clerk/backend.
CLERK_JWT_KEY=
# Optional: only set after a Clerk JWT template/session token emits the same
# aud claim and the frontend requests that token intentionally.
CLERK_AUDIENCE=
# Comma-separated allowed frontend origins, for example:
# https://app.example.com,https://staging.example.com
CLERK_AUTHORIZED_PARTIES=
VITE_CLERK_PUBLISHABLE_KEY=
# Reserved until a Clerk webhook route is mounted.
CLERK_WEBHOOK_SECRET=
CLERK_SIGN_IN_URL=http://localhost:5173/sign-in
CLERK_SIGN_UP_URL=http://localhost:5173/sign-up
CLERK_AFTER_SIGN_IN_URL=http://localhost:5173/auth/session
CLERK_AFTER_SIGN_UP_URL=http://localhost:5173/auth/session
CLERK_INVITATION_REDIRECT_URL=http://localhost:5173/auth/session

# Storage
# Cloudflare R2 application object storage.
# Used by inventory media, generated vehicle documents, finance attachments,
# CRM WhatsApp inbound media mirroring, and future domain files.
# Browser uploads also require the bucket CORS policy in docs/ops/r2-cors.md.
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=
R2_REGION=auto
R2_UPLOAD_URL_EXPIRES_SECONDS=900
R2_DOWNLOAD_URL_EXPIRES_SECONDS=300

# Marketplace provider integrations.
# Use a strong random value in production; used for encrypted provider tokens.
MARKETPLACE_CREDENTIAL_ENCRYPTION_KEY=
MERCADO_LIVRE_CLIENT_ID=
MERCADO_LIVRE_CLIENT_SECRET=
MERCADO_LIVRE_AUTHORIZATION_URL=https://auth.mercadolivre.com.br/authorization
MERCADO_LIVRE_API_BASE_URL=https://api.mercadolibre.com
MERCADO_LIVRE_TOKEN_URL=https://api.mercadolibre.com/oauth/token
OLX_CLIENT_ID=
OLX_CLIENT_SECRET=
OLX_AUTHORIZATION_URL=
OLX_API_BASE_URL=
OLX_TOKEN_URL=
OLX_LISTINGS_PATH=/listings

# Authless seeded preview only. Leave empty when testing real Clerk.
LOCAL_AUTH_BYPASS=
DEV_CLERK_USER_ID=
DEV_STORE_SLUG=
VITE_LOCAL_AUTH_BYPASS=
VITE_DEV_CLERK_USER_ID=
VITE_DEV_STORE_SLUG=
VITE_DEV_CLERK_SESSION_TOKEN=

# Billing
ASAAS_RUNTIME_IMPLEMENTATION=
ASAAS_API_KEY=
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_SECRET=
PAYMENT_MODE=MOCK

# Integrations
FIPE_API_BASE_URL=https://parallelum.com.br/fipe/api/v2
FIPE_API_TOKEN=
FIPE_CATALOG_SYNC_BRAND_CODES=
FIPE_CATALOG_SYNC_BRAND_LIMIT=
FIPE_CATALOG_SYNC_CONCURRENCY=1
FIPE_CATALOG_SYNC_HTTP_MAX_ATTEMPTS=5
FIPE_CATALOG_SYNC_INCLUDE_YEARS=true
FIPE_CATALOG_SYNC_HTTP_RETRY_BASE_MS=1000
FIPE_CATALOG_SYNC_REFERENCE_CODE=
FIPE_CATALOG_SYNC_REFRESH_AFTER_DAYS=30
FIPE_CATALOG_SYNC_REFRESH_EXISTING=false
FIPE_CATALOG_SYNC_VEHICLE_TYPES=cars,motorcycles,trucks
OPENROUTER_API_KEY=
CLICKSIGN_ACCESS_TOKEN=
CLICKSIGN_WEBHOOK_SECRET=
API_PLACA_KEY=
API_PLACA_BASE_URL=https://gateway.apibrasil.io/api/v2
API_PLACA_DADOS_PATH=/vehicles/base/000/dados
API_PLACA_CACHE_TTL_DAYS=30
API_OPENAI_KEY=
API_OPENAI_DEFAULT_MODEL=gpt-5.4-mini
API_OPENAI_INVENTORY_RESALE_MODEL=
API_OPENAI_MODEL=
CREDERE_CLIENT_ID=
CREDERE_CLIENT_SECRET=
MERCADO_LIVRE_CLIENT_ID=
MERCADO_LIVRE_CLIENT_SECRET=
WEBMOTORS_CLIENT_ID=
WEBMOTORS_CLIENT_SECRET=
OLX_CLIENT_ID=
OLX_CLIENT_SECRET=
ICARROS_CLIENT_ID=
ICARROS_CLIENT_SECRET=

# Fiscal / NF-e provider
# Set SPEDY_RUNTIME_IMPLEMENTATION=http only after the provider contract,
# credentials, endpoints, and webhook secret are configured.
SPEDY_RUNTIME_IMPLEMENTATION=
SPEDY_API_URL=
SPEDY_API_TOKEN=
SPEDY_AUTH_HEADER=Authorization
SPEDY_AUTH_SCHEME=Bearer
SPEDY_WEBHOOK_SECRET=
SPEDY_ISSUE_PATH=
SPEDY_CANCEL_PATH=
SPEDY_STATUS_PATH=

# Production/public routing
APP_PRIMARY_DOMAIN=
API_PRIMARY_DOMAIN=
PUBLIC_STOREFRONT_ROOT_DOMAIN=lojaveiculos.com.br
PUBLIC_STOREFRONT_CUSTOM_DOMAIN_CNAME_TARGET=
CLERK_SIGN_IN_URL=
CLERK_SIGN_UP_URL=
CLERK_AFTER_SIGN_IN_URL=
CLERK_AFTER_SIGN_UP_URL=
CLERK_INVITATION_REDIRECT_URL=

# Provider webhooks
ASAAS_WEBHOOK_URL=
SPEDY_WEBHOOK_URL=
MERCADO_LIVRE_WEBHOOK_URL=
OLX_WEBHOOK_URL=

# Observability
LOG_LEVEL=info
EXTERNAL_API_RATE_LIMIT_PER_MINUTE=120
OTEL_EXPORTER_OTLP_ENDPOINT=
