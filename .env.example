# Runtime
NODE_ENV=development
APP_ENV=local
PORT=8787
PUBLIC_APP_URL=http://localhost:5173
API_BASE_URL=http://localhost:8787
VITE_API_BASE_URL=/api/v1
VITE_DEV_API_PROXY_TARGET=http://localhost:8787
VITE_DEV_PUBLIC_STORE_HOST=test-store.lojaveiculos.com.br
DB_POOL_MAX=5

# Product databases
# Local Docker defaults. These are development-only credentials from docker-compose.yml.
DATABASE_URL=postgresql://lojaveiculosv2:lojaveiculosv2_dev@localhost:54321/lojaveiculosv2
AUDIT_DATABASE_URL=postgresql://lojaveiculosv2_audit:lojaveiculosv2_audit_dev@localhost:54322/lojaveiculosv2_audit

# Railway production values should be reference variables in the existing
# repasses-backend project, not copied local URLs:
# DATABASE_URL=${{lojaveiculosv2-postgres.DATABASE_URL}}
# AUDIT_DATABASE_URL=${{lojaveiculosv2-audit-postgres.DATABASE_URL}}

# Optional infra services
# REDIS_URL=${{redis.REDIS_URL}}
REDIS_URL=

# CRM backend integration
# Local value can point to a tunnel or Railway public domain while Repasses
# backend remains a separate service.
REPASSES_CRM_API_URL=https://${{repasses-backend.RAILWAY_PUBLIC_DOMAIN}}/api/v1

# Clerk
# Same Clerk instance should be used by V2 and repasses backend.
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# Storage
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=

# Billing
ASAAS_API_KEY=
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_SECRET=
PAYMENT_MODE=MOCK

# Integrations
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
OPENROUTER_API_KEY=
CLICKSIGN_ACCESS_TOKEN=
CLICKSIGN_WEBHOOK_SECRET=
API_PLACA_KEY=
CREDERE_CLIENT_ID=
CREDERE_CLIENT_SECRET=
MERCADO_LIVRE_CLIENT_ID=
MERCADO_LIVRE_CLIENT_SECRET=
WEBMOTORS_CLIENT_ID=
WEBMOTORS_CLIENT_SECRET=
OLX_CLIENT_ID=
OLX_CLIENT_SECRET=
ICARROS_CLIENT_ID=
ICARROS_CLIENT_SECRET=

# Observability
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
